# ============================================
# BizTrip Agent 配置文件
# 复制此文件为 .env 并填入你的信息
#   cp .env.example .env
# ============================================

# --- 邮箱配置（必需）---
# 选择一个邮箱服务商，取消注释对应配置即可

# 账号和授权码（各服务商通用）
EMAIL_ACCOUNT=your_email@example.com
EMAIL_PASSWORD=your_authorization_code_or_password

# IMAP 服务器和端口（选一个取消注释）
# QQ 邮箱
# EMAIL_IMAP_SERVER=imap.qq.com
# EMAIL_IMAP_PORT=993

# 163 邮箱
# EMAIL_IMAP_SERVER=imap.163.com
# EMAIL_IMAP_PORT=993

# 126 邮箱
# EMAIL_IMAP_SERVER=imap.126.com
# EMAIL_IMAP_PORT=993

# Gmail（需开启两步验证 + 应用专用密码）
# EMAIL_IMAP_SERVER=imap.gmail.com
# EMAIL_IMAP_PORT=993

# Outlook / Hotmail
# EMAIL_IMAP_SERVER=outlook.office365.com
# EMAIL_IMAP_PORT=993

# 自定义 IMAP 服务器（企业邮箱等）
# EMAIL_IMAP_SERVER=imap.your-company.com
# EMAIL_IMAP_PORT=993

# --- LLM 配置（可选，不配则走纯规则引擎）---
# 支持任何兼容 OpenAI 协议的服务商

# API Key（从服务商获取）
LLM_API_KEY=sk-your-api-key

# API 地址（不同服务商地址不同）
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
LLM_MODEL=deepseek-chat

# ============================================
# 常见服务商配置示例（把对应三行取消注释即可）
# ============================================

# --- DeepSeek ---
# 获取 Key: https://platform.deepseek.com/api_keys
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# --- 阿里云百炼（通义千问）---
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- 智谱 AI（GLM）---
# LLM_API_KEY=xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# --- 月之暗面（Kimi）---
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# --- SiliconFlow（模型聚合）---
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- 火山引擎（豆包）---
# LLM_API_KEY=xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=ep-xxxxxxxxxx

# --- Ollama 本地模型（完全免费）---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
